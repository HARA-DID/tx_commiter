# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
STREAM_NAME=did-events
GROUP_NAME=did-worker-group
DLQ_SUFFIX=:dlq

# ── Database ───────────────────────────────────────────────────────────────
DB_URL=postgres://postgres:secret@localhost:5432/workerdb?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ── Blockchain ─────────────────────────────────────────────────────────────
# Comma-separated RPC URLs (hara-core-blockchain-lib NewNetwork)
RPC_URLS=https://rpc1.hara.network,https://rpc2.hara.network

# Hex-encoded ECDSA private key (NewWallet)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── HNS Contract Resolution ────────────────────────────────────────────────
# All contracts are resolved exclusively via HNS URI

# Account Abstraction
AA_ENTRYPOINT_HNS=entrypoint.aa.hara.ethnet
AA_GAS_MANAGER_HNS=gasmanager.aa.hara.ethnet
AA_WALLET_HNS=wallet.aa.hara.ethnet
AA_WALLET_FACTORY_HNS=walletfactory.aa.hara.ethnet

# DID Root
DID_ROOT_FACTORY_HNS=didfactory.root.hara.ethnet
DID_ROOT_STORAGE_HNS=rootregistry.root.hara.ethnet
DID_ORG_STORAGE_HNS=orgregistry.root.hara.ethnet

# Verifiable Credentials
DID_VC_FACTORY_HNS=vcfactory.vc.hara.ethnet
DID_VC_STORAGE_HNS=vcstorage.vc.hara.ethnet
DID_VC_CERTIFICATE_NFT_HNS=certnft.vc.hara.ethnet
DID_VC_IDENTITY_NFT_HNS=idnft.vc.hara.ethnet

# Alias
DID_ALIAS_FACTORY_HNS=aliasfactory.alias.hara.ethnet
DID_ALIAS_STORAGE_HNS=aliasstorage.alias.hara.ethnet

# ── Worker ─────────────────────────────────────────────────────────────────
CONSUMER_NAME=worker-1
WORKER_CONCURRENCY=10
POLL_INTERVAL=100ms
MAX_RETRY=3
RETRY_BASE_DELAY=1s
SHUTDOWN_TIMEOUT=30s
BATCH_SIZE=10

# ── HTTP server ────────────────────────────────────────────────────────────
SERVER_PORT=8080
LOG_LEVEL=info
RPC_TIMEOUT=3000
VERSION=v1
